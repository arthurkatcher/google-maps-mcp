# Get a key: https://console.cloud.google.com/apis/credentials
# Enable: Places API (New), Directions API, Geocoding API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Only needed for HTTP mode. If you change MCP_HOST off 127.0.0.1
# (e.g. to expose via ngrok or a reverse proxy), set MCP_API_KEY to a
# random secret — your GOOGLE_MAPS_API_KEY is billable and the server
# will otherwise serve any request that reaches it.
MCP_API_KEY=
MCP_HOST=127.0.0.1
MCP_PORT=8000
